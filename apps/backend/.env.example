# 本地开发：先执行 pnpm db:up 启动 Redis、MongoDB，再 pnpm --filter backend dev
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/memorize

# 服务端口（可选，默认 3000）
PORT=3000

# 邮件服务（如 163：smtp.163.com:465，需在邮箱设置中开启 SMTP 并获取授权码）
MAILER_HOST=smtp.example.com
MAILER_PORT=465
MAILER_USER=your_email@example.com
MAILER_PASS=your_smtp_authorization_code

# 数据库（当前配置为 PostgreSQL；若未使用可留空或注释）
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password

# Redis（若已用 REDIS_URL 可二选一）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
