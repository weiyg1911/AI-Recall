{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_checkHealth",
        "summary": "检查服务是否正常运行",
        "parameters": [],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok",
                    "timestamp": "2025-01-01T00:00:00.000Z"
                  }
                }
              }
            }
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/ping": {
      "get": {
        "operationId": "HealthController_ping",
        "summary": "简单连通性检查",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回 pong"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/authTime": {
      "get": {
        "operationId": "HealthController_getServerTime",
        "summary": "获取服务器时间",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回服务器时间"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/errorException": {
      "get": {
        "operationId": "HealthController_errorException",
        "summary": "测试错误异常",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回错误异常"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/auth/send-otp": {
      "post": {
        "operationId": "AuthController_sendOtp",
        "summary": "发送验证码",
        "description": "向指定的邮箱发送注册登录相关的 6 位验证码",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendOtpDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "是否成功发送邮件",
            "content": {
              "application/json": {
                "schema": {
                  "type": "boolean"
                }
              }
            }
          }
        },
        "tags": ["用户认证"]
      }
    },
    "/auth/verify-otp": {
      "post": {
        "operationId": "AuthController_verifyOtp",
        "summary": "验证邮箱验证码",
        "description": "验证通过后将下发访问 Token",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyOtpDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "验证结果及对应的身份 Token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyOtpResponseDto"
                }
              }
            }
          }
        },
        "tags": ["用户认证"]
      }
    },
    "/knowledge": {
      "post": {
        "operationId": "KnowledgeController_getKnowledgeList",
        "summary": "获取知识点列表",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PageDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "返回分页的知识点列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeListResponseDto"
                }
              }
            }
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/create": {
      "post": {
        "operationId": "KnowledgeController_createKnowledge",
        "summary": "创建知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKnowledgeDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "title": "谚语",
                    "content": "不到长城非好汉"
                  }
                },
                "example2": {
                  "value": {
                    "content": "title 可以为空"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "知识点创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeBaseResponseDto"
                }
              }
            }
          }
        },
        "tags": ["知识点管理"],
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/knowledge/detail": {
      "post": {
        "operationId": "KnowledgeController_getKnowledgeDetail",
        "summary": "知识点详情",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DelKnowledgeDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/update": {
      "post": {
        "operationId": "KnowledgeController_updateKnowledge",
        "summary": "更新知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateKnowledgeDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/delete": {
      "post": {
        "operationId": "KnowledgeController_delKnowledge",
        "summary": "删除知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DelKnowledgeDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    }
  },
  "info": {
    "title": "背书记忆 API",
    "description": "Agent 背书记忆项目接口文档",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SendOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "test@example.com",
            "description": "接收验证码的邮箱地址"
          }
        },
        "required": ["email"]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "test@example.com",
            "description": "需要登录或注册的邮箱地址"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "邮箱收到的6位数验证码"
          }
        },
        "required": ["email", "code"]
      },
      "VerifyOtpResponseDto": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean",
            "example": true,
            "description": "验证结果，true 代表验证成功"
          },
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJ...xxx",
            "description": "验证成功后派发的身份 Token"
          }
        },
        "required": ["result"]
      },
      "PageDto": {
        "type": "object",
        "properties": {
          "page": {
            "type": "number",
            "example": 1,
            "description": "页码"
          },
          "pageSize": {
            "type": "number",
            "example": 10,
            "description": "每页数量"
          }
        },
        "required": ["page", "pageSize"]
      },
      "KnowledgeListResponseDto": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number",
            "example": 1,
            "description": "总数"
          },
          "page": {
            "type": "number",
            "example": 10,
            "description": "当前页"
          },
          "pageSize": {
            "type": "number",
            "example": 10,
            "description": "每页数量"
          },
          "data": {
            "example": [],
            "description": "数据",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["total", "page", "pageSize", "data"]
      },
      "CreateKnowledgeDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "谚语",
            "description": "知识点标题"
          },
          "content": {
            "type": "string",
            "example": "不到长城非好汉",
            "description": "知识点内容"
          }
        },
        "required": ["content"]
      },
      "KnowledgeInfoItemDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "text",
            "enum": ["text", "cloze"],
            "description": "内容类型"
          },
          "content": {
            "type": "string",
            "example": "不到长城非好汉",
            "description": "具体内容片段"
          }
        },
        "required": ["type", "content"]
      },
      "KnowledgeBaseResponseDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "谚语",
            "description": "知识点标题"
          },
          "infoList": {
            "description": "知识点结构化拆解内容",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KnowledgeInfoItemDto"
            }
          }
        },
        "required": ["title", "infoList"]
      },
      "DelKnowledgeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "DelKnowledgeDto_id",
            "description": "知识点id"
          }
        },
        "required": ["id"]
      },
      "UpdateKnowledgeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011",
            "description": "知识点 id"
          },
          "title": {
            "type": "string",
            "example": "谚语",
            "description": "知识点标题"
          },
          "content": {
            "type": "string",
            "example": "不到长城非好汉",
            "description": "知识点正文"
          }
        },
        "required": ["id", "content"]
      }
    }
  }
}
