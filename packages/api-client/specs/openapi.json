{
  "openapi": "3.0.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "HealthController_checkHealth",
        "summary": "检查服务是否正常运行",
        "parameters": [],
        "responses": {
          "200": {
            "description": "服务正常",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok",
                    "timestamp": "2025-01-01T00:00:00.000Z"
                  }
                }
              }
            }
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/ping": {
      "get": {
        "operationId": "HealthController_ping",
        "summary": "简单连通性检查",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回 pong"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/authTime": {
      "get": {
        "operationId": "HealthController_getServerTime",
        "summary": "获取服务器时间",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回服务器时间"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/health/errorException": {
      "get": {
        "operationId": "HealthController_errorException",
        "summary": "测试错误异常",
        "parameters": [],
        "responses": {
          "200": {
            "description": "返回错误异常"
          }
        },
        "tags": ["健康检查"]
      }
    },
    "/auth/send-otp": {
      "post": {
        "operationId": "AuthController_sendOtp",
        "summary": "发送验证码",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendOtpDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "email": "123@123.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "返回验证码"
          }
        },
        "tags": ["认证"]
      }
    },
    "/auth/verify-otp": {
      "post": {
        "operationId": "AuthController_verifyOtp",
        "summary": "验证邮箱验证码",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyOtpDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "email": "123@123.com",
                    "code": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "返回验证结果"
          }
        },
        "tags": ["认证"]
      }
    },
    "/knowledge": {
      "post": {
        "operationId": "KnowledgeController_getKnowledgeList",
        "parameters": [],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/create": {
      "post": {
        "operationId": "KnowledgeController_createKnowledge",
        "summary": "创建知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateKnowledgeDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "title": "谚语",
                    "content": "不到长城非好汉"
                  }
                },
                "example2": {
                  "value": {
                    "content": "title 可以为空"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/detail": {
      "post": {
        "operationId": "KnowledgeController_getKnowledgeDetail",
        "summary": "知识点详情",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DelKnowledgeDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "id": "507f1f77bcf86cd799439011"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/update": {
      "post": {
        "operationId": "KnowledgeController_updateKnowledge",
        "summary": "更新知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateKnowledgeDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "id": "507f1f77bcf86cd799439011",
                    "title": "新标题",
                    "content": "更新后的正文内容"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    },
    "/knowledge/delete": {
      "post": {
        "operationId": "KnowledgeController_delKnowledge",
        "summary": "删除知识点",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DelKnowledgeDto"
              },
              "examples": {
                "example1": {
                  "value": {
                    "id": "123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "tags": ["知识点管理"]
      }
    }
  },
  "info": {
    "title": "背书记忆 API",
    "description": "Agent 背书记忆项目接口文档",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SendOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "sendOtpDto@example.com",
            "description": "邮箱地址"
          }
        },
        "required": ["email"]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "VerifyOtpDto@example.com",
            "description": "邮箱地址"
          },
          "code": {
            "type": "string",
            "example": "123456",
            "description": "验证码"
          }
        },
        "required": ["email", "code"]
      },
      "CreateKnowledgeDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "谚语",
            "description": "知识点标题"
          },
          "content": {
            "type": "string",
            "example": "不到长城非好汉",
            "description": "知识点内容"
          }
        },
        "required": ["title", "content"]
      },
      "DelKnowledgeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "DelKnowledgeDto_id",
            "description": "知识点id"
          }
        },
        "required": ["id"]
      },
      "UpdateKnowledgeDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "507f1f77bcf86cd799439011",
            "description": "知识点 id"
          },
          "title": {
            "type": "string",
            "example": "谚语",
            "description": "知识点标题"
          },
          "content": {
            "type": "string",
            "example": "不到长城非好汉",
            "description": "知识点正文"
          }
        },
        "required": ["id", "content"]
      }
    }
  }
}
